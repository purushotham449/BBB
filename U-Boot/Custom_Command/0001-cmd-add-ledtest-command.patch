From 1ae3639748ca0d0bae70f2fde9db18c1928632b5 Mon Sep 17 00:00:00 2001
From: Purushotham <purushotham.449@gmail.com>
Date: Sun, 8 Mar 2026 00:24:59 +0530
Subject: [PATCH] cmd: add ledtest command for BBB

Signed-off-by: Purushotham <purushotham.449@gmail.com>
---
 cmd/Kconfig                  |  6 +++++
 cmd/Makefile                 |  1 +
 cmd/cmd_ledtest.c            | 46 ++++++++++++++++++++++++++++++++++++
 configs/am335x_evm_defconfig |  3 +++
 4 files changed, 56 insertions(+)
 create mode 100644 cmd/cmd_ledtest.c

diff --git a/cmd/Kconfig b/cmd/Kconfig
index 02c298fdbe4..05ff8e88e3e 100644
--- a/cmd/Kconfig
+++ b/cmd/Kconfig
@@ -151,6 +151,12 @@ config CMD_PMC
 	  changing the state but it is still useful for debugging and seeing
 	  what is going on.
 
+config CMD_LEDTEST
+    bool "LED Test command"
+    depends on CMD_GPIO
+    help
+      Enable custom LED test command for debugging.
+	  
 config CMD_REGINFO
 	bool "reginfo"
 	depends on PPC
diff --git a/cmd/Makefile b/cmd/Makefile
index e31ac15ef75..fbb6adcd852 100644
--- a/cmd/Makefile
+++ b/cmd/Makefile
@@ -255,3 +255,4 @@ $(obj)/license_data_size.h: $(srctree)/Licenses/gpl-2.0.txt FORCE
 	$(call filechk,data_size)
 
 CFLAGS_ethsw.o := -Wno-enum-conversion
+obj-$(CONFIG_CMD_LEDTEST) += cmd_ledtest.o
diff --git a/cmd/cmd_ledtest.c b/cmd/cmd_ledtest.c
new file mode 100644
index 00000000000..537e7235e1e
--- /dev/null
+++ b/cmd/cmd_ledtest.c
@@ -0,0 +1,46 @@
+// SPDX-License-Identifier: GPL-2.0+
+#include <common.h>
+#include <command.h>
+#include <asm/gpio.h>
+#include <linux/delay.h>
+
+#define LED0 53
+#define LED1 54
+#define LED2 55
+#define LED3 56
+
+static int do_ledtest(struct cmd_tbl *cmdtp, int flag, int argc, char * const argv[])
+{
+    int leds[] = { LED0, LED1, LED2, LED3 };
+    int i, j;
+
+    printf("U-Boot USER LED GPIO test\n");
+
+    for (i = 0; i < 4; i++) {
+        if (gpio_request(leds[i], "led")) {
+            printf("FAIL: GPIO %d request failed\n", leds[i]);
+            return CMD_RET_FAILURE;
+        }
+        gpio_direction_output(leds[i], 0);
+    }
+
+    for (j = 0; j < 5; j++) {
+        for (i = 0; i < 4; i++) {
+            gpio_set_value(leds[i], 1);
+            mdelay(200);
+            gpio_set_value(leds[i], 0);
+        }
+    }
+
+    for (i = 0; i < 4; i++)
+        gpio_free(leds[i]);
+
+    printf("LED test PASS\n");
+    return CMD_RET_SUCCESS;
+}
+
+//#ifndef CONFIG_SPL_BUILD
+U_BOOT_CMD(
+    ledtest, 1, 0, do_ledtest,
+    "Test BeagleBone USER LEDs",
+    ""
+);
+//#endif
diff --git a/configs/am335x_evm_defconfig b/configs/am335x_evm_defconfig
index 4dc5d0fe347..436065ee7dc 100644
--- a/configs/am335x_evm_defconfig
+++ b/configs/am335x_evm_defconfig
@@ -101,3 +101,6 @@ CONFIG_WDT=y
 CONFIG_DYNAMIC_CRC_TABLE=y
 CONFIG_RSA=y
 CONFIG_LZO=y
+CONFIG_CMD_GPIO=y
+CONFIG_GPIO=y
+CONFIG_CMD_LEDTEST=y
-- 
