 CONFIG_DYNAMIC_CRC_TABLE=y
 CONFIG_RSA=y
 CONFIG_LZO=y
+CONFIG_CMD_DIAG=y
+CONFIG_CMD_DIAG_BMP280=y
+CONFIG_CMD_DIAG_TMP102=y
+CONFIG_CMD_DIAG_DS3231=y
+CONFIG_CMD_DIAG_MPU6050=y
+CONFIG_CMD_DIAG_OLED=y
+CONFIG_SYS_I2C=y
